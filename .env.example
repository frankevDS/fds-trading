# Copy this file to .env for local `vercel dev` testing.
# In production (Vercel), set these under Project > Settings > Environment
# Variables instead.

# AI Analyse needs ONE of these two. If both are set, ANTHROPIC_API_KEY wins
# unless you force it with AI_PROVIDER below.

# Option A - Anthropic (Claude). Paid, pay-as-you-go.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option B - Groq. Free, no credit card, runs open models (Llama etc).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional - force which provider to use when both keys are set.
# Set to "anthropic" or "groq". Leave blank to auto-pick (Anthropic first).
AI_PROVIDER=

# Binance Testnet keys are NOT set as env vars - you connect them from inside
# the app's BROKER tab, and they're stored in your browser only.

# Telegram signal alerts - optional but recommended.
# Create a bot via @BotFather in Telegram, then paste the token here.
# See the ALERTS tab in the app for full setup instructions.
TELEGRAM_BOT_TOKEN=
