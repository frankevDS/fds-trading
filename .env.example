# Copy this file to .env and fill in your own key for local `vercel dev` testing.
# In production (Vercel), set this under Project > Settings > Environment Variables instead.

# Required for the "AI ANALYSE" feature (api/analyze.js).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Binance Testnet keys are NOT set as env vars - you connect them from inside
# the app's BROKER tab, and they're stored in your browser only.
